{
  "name": "@fmmenchi/ci",
  "version": "0.0.1",
  "description": "CI helper scripts for an Nx release monorepo — prints the releasable projects Nx marks affected between two refs.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fmmenchi/shared-platform.git",
    "directory": "packages/tools/ci"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@fmmenchi/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "nx": {
    "tags": [
      "scope:tools",
      "type:util"
    ]
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ]
}
