{
  "name": "@fmmenchi/nx-trivy",
  "version": "0.0.1",
  "description": "Nx executor that runs Trivy security scans — workspace-wide dependency-vulnerability scanning by default.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fmmenchi/shared-platform.git",
    "directory": "packages/plugins/trivy"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "type": "commonjs",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@fmmenchi/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "nx": {
    "targets": {
      "scan": {
        "executor": "@fmmenchi/nx-trivy:scan",
        "dependsOn": [
          "build"
        ]
      },
      "scan-docker": {
        "executor": "@fmmenchi/nx-trivy:scan",
        "dependsOn": [
          "build"
        ],
        "options": {
          "runner": "docker"
        }
      },
      "scan-secrets": {
        "executor": "@fmmenchi/nx-trivy:scan",
        "dependsOn": [
          "build"
        ],
        "options": {
          "scanners": "secret",
          "extraArgs": [
            "--skip-dirs",
            "**/node_modules",
            "--skip-dirs",
            "**/dist",
            "--skip-dirs",
            "**/build",
            "--skip-dirs",
            "**/.nx",
            "--skip-dirs",
            ".git"
          ]
        }
      },
      "scan-secrets-docker": {
        "executor": "@fmmenchi/nx-trivy:scan",
        "dependsOn": [
          "build"
        ],
        "options": {
          "runner": "docker",
          "scanners": "secret",
          "extraArgs": [
            "--skip-dirs",
            "**/node_modules",
            "--skip-dirs",
            "**/dist",
            "--skip-dirs",
            "**/build",
            "--skip-dirs",
            "**/.nx",
            "--skip-dirs",
            ".git"
          ]
        }
      },
      "sbom": {
        "executor": "@fmmenchi/nx-trivy:sbom",
        "dependsOn": [
          "build"
        ]
      },
      "build": {
        "executor": "@nx/js:tsc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "packages/plugins/trivy/dist",
          "main": "packages/plugins/trivy/src/index.ts",
          "tsConfig": "packages/plugins/trivy/tsconfig.lib.json",
          "rootDir": "packages/plugins/trivy/src",
          "generatePackageJson": false,
          "assets": [
            {
              "input": "./packages/plugins/trivy/src",
              "glob": "**/!(*.ts)",
              "output": "."
            },
            {
              "input": "./packages/plugins/trivy/src",
              "glob": "**/*.d.ts",
              "output": "."
            }
          ]
        }
      }
    },
    "tags": [
      "scope:plugins",
      "type:plugin"
    ]
  },
  "dependencies": {
    "@nx/devkit": "23.1.0",
    "@nx/js": "23.1.0",
    "tslib": "^2.3.0"
  },
  "executors": "./executors.json",
  "files": [
    "dist",
    "!**/*.tsbuildinfo",
    "executors.json"
  ]
}
