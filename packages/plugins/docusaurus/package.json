{
  "name": "@fmmenchi/nx-docusaurus",
  "version": "0.0.1",
  "type": "commonjs",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@fmmenchi/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "nx": {
    "targets": {
      "build": {
        "executor": "@nx/js:tsc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "packages/plugins/docusaurus/dist",
          "main": "packages/plugins/docusaurus/src/index.ts",
          "tsConfig": "packages/plugins/docusaurus/tsconfig.lib.json",
          "rootDir": "packages/plugins/docusaurus/src",
          "generatePackageJson": false,
          "assets": [
            {
              "input": "./packages/plugins/docusaurus/src",
              "glob": "**/!(*.ts)",
              "output": "."
            },
            {
              "input": "./packages/plugins/docusaurus/src",
              "glob": "**/*.d.ts",
              "output": "."
            }
          ]
        }
      }
    },
    "tags": [
      "scope:plugins",
      "type:plugin"
    ]
  },
  "dependencies": {
    "@nx/devkit": "23.1.0",
    "tslib": "^2.3.0"
  },
  "generators": "./generators.json",
  "executors": "./executors.json",
  "files": [
    "dist",
    "!**/*.tsbuildinfo",
    "generators.json",
    "executors.json"
  ],
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fmmenchi/shared-platform.git",
    "directory": "packages/plugins/docusaurus"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
