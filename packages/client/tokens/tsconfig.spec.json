{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./out-tsc/vitest",
    "types": ["vitest/globals", "node", "vitest"],
    "module": "esnext",
    "moduleResolution": "bundler"
  },
  "include": [
    "vite.config.mts",
    "vitest.config.mts",
    "types/**/*.d.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts"
  ],
  "references": [
    {
      "path": "./tsconfig.lib.json"
    }
  ]
}
