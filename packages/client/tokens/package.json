{
  "name": "@fmmenchi/tokens",
  "version": "0.0.1",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fmmenchi/shared-platform.git",
    "directory": "packages/client/tokens"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "dist",
    "src/styles"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@fmmenchi/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./validate": {
      "@fmmenchi/source": "./src/validate.ts",
      "types": "./dist/validate.d.ts",
      "import": "./dist/validate.js",
      "default": "./dist/validate.js"
    },
    "./styles/tailwind.css": "./src/styles/tailwind.css",
    "./styles/vars.css": "./src/styles/vars.css",
    "./styles/presets/dark.css": "./src/styles/presets/dark.css"
  },
  "nx": {
    "tags": [
      "scope:client",
      "type:util"
    ]
  },
  "dependencies": {
    "culori": "^4.0.2",
    "tslib": "^2.3.0"
  }
}
