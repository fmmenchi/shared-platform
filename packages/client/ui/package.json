{
  "name": "@fmmenchi/ui",
  "version": "0.0.1",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fmmenchi/shared-platform.git",
    "directory": "packages/client/ui"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@fmmenchi/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./button": {
      "@fmmenchi/source": "./src/components/button/index.ts",
      "types": "./dist/components/button/index.d.ts",
      "import": "./dist/button.js",
      "default": "./dist/button.js"
    },
    "./style.css": "./dist/style.css",
    "./button/style.css": "./dist/button.css"
  },
  "nx": {
    "tags": [
      "scope:client",
      "type:ui"
    ]
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@fmmenchi/tokens": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0",
    "tslib": "^2.3.0"
  }
}
